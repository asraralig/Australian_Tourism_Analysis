-- QUESTION 7: Return Visitor Loyalty Analysis
-- Analysis: Are people coming back? Which countries have loyal customers?
-- Result: LOYALTY CRISIS with China (lowest return rate despite #1 market)

select 
Country,
SUM(Visitors) as total_visitors,
SUM(Returning_Visitors) as total_Returning_Visitors,
(SUM(Returning_Visitors)*100)/SUM(Visitors) as return_percentage
from Visitor_Arrivals
group by Country
order by return_percentage DESC


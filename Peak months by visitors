-- QUESTION 3: Peak Months (Seasonality Analysis)
-- Analysis: When do we have peak visitors?
-- Result: December peak (321K) vs August low (112K) = 2.87x variation

SELECT TOP 12
    MONTH,
    SUM(Visitors) AS total_visitors_per_month,
    ROUND(AVG(Visitors), 0) AS avg_visitors_per_month,
    COUNT(DISTINCT Country) AS countries_in_month
FROM Visitor_Arrivals
GROUP BY MONTH
ORDER BY total_visitors_per_month DESC;

